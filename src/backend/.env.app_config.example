APP_CONFIG__ENVIRONMENT=dev
APP_CONFIG__RUN__HOST=0.0.0.0
APP_CONFIG__RUN__PORT=8000
APP_CONFIG__CORS__ALLOW_ORIGINS=http://localhost

APP_CONFIG__DB__URL=postgresql+asyncpg://postgres:1234@pg:5432/postgres

APP_CONFIG__LLM__API_KEY=your_api_key_here
APP_CONFIG__LLM__API_BASE=https://openrouter.ai/api/v1
APP_CONFIG__LLM__DEFAULT_MODEL=openrouter/free
APP_CONFIG__LLM__TEMPERATURE=0.7
APP_CONFIG__LLM__MAX_TOKENS=1024
APP_CONFIG__LLM__REQUEST_TIMEOUT=30
APP_CONFIG__LLM__MAX_AGENT_STEPS=6
APP_CONFIG__LLM__EMBEDDING_MODE=local
APP_CONFIG__LLM__EMBEDDING_MODEL=text-embedding-3-small

APP_CONFIG__SENTRY__DSN=
